# Supabase (projet cloud — https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_cle_anon_ou_publishable
SUPABASE_SERVICE_ROLE_KEY=votre_cle_secrete_sb_secret

# Resend (emails transactionnels — https://resend.com)
RESEND_API_KEY=re_votre_cle_api
RESEND_FROM_EMAIL=Globus Livraison x La Vélopostale <noreply@lavelopostale-commande.ch>

# Destinataires emails (configurables pour tests)
DISPATCH_EMAIL=dispo@coursier.ch
GLOBUS_NOTIFICATION_EMAIL=livraison@globus.ch

# Optionnel : rediriger tous les emails vers une boîte de test
# DISPATCH_EMAIL=test@example.com
# GLOBUS_NOTIFICATION_EMAIL=test@example.com

# Logtech (API Vélopostale — production)
LOGTECH_API_URL=https://api.logtech.ch
LOGTECH_API_KEY=votre_cle_api_logtech
# Adresse client Globus envoyée à Logtech (facturation)
LOGTECH_CUSTOMER_COMPANY=Globus Genève
LOGTECH_CUSTOMER_ADDRESS=Rue du Rhône 48, 1204 Genève
